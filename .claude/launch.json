{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ave-backend",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["src.web.app:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "ave-studio",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "src/web/studio", "dev", "--port", "3000"],
      "port": 3000
    }
  ]
}
